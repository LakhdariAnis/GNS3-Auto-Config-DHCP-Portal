# ============================================================
#  GNS3 Auto-Config DHCP Portal — .gitignore
# ============================================================

# ---------------------------
# Python (backend/)
# ---------------------------
venv/
__pycache__/
*.py[cod]
*.pyo
.env
.env.local
*.egg-info/
dist/
build/

# ---------------------------
# Node / Next.js (dhcp-config-app/ AND backend/node_modules)
# ---------------------------
node_modules/
.next/
out/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json

# ---------------------------
# GNS3 — Exclude runtime junk, keep topology + configs
# ---------------------------

# Packet captures (large binary files — useless without a running topology)
MiniProjet/project-files/captures/*.pcap

# Hypervisor runtime logs (regenerated every run)
MiniProjet/project-files/dynamips/**/*_log.txt
MiniProjet/project-files/dynamips/**/*_stdout.txt

# VPCS runtime logs
MiniProjet/project-files/vpcs/**/vpcs.log

# GNS3 auto-backup (redundant with the main .gns3 file)
MiniProjet/*.gns3.backup

# Builtin node folder (GNS3 internal, not portable)
MiniProjet/project-files/builtin/

# Images folder (IOS image binaries — too large & proprietary)
MiniProjet/project-files/images/

# ---------------------------
# OS & Editor junk
# ---------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

